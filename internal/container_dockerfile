# Yoe-NG build container (Tier 0)
# Version: 1
#
# This Dockerfile is embedded in the yoe binary. The host yoe copies itself
# into the container rather than rebuilding from source.

FROM alpine:3.21

RUN apk add --no-cache \
    bubblewrap \
    apk-tools \
    git \
    tar \
    gzip \
    bzip2 \
    xz \
    patch \
    coreutils \
    bash \
    make \
    gcc \
    g++ \
    musl-dev \
    linux-headers

# The yoe binary is copied in during docker build (from build context)
COPY yoe /usr/local/bin/yoe

ENV YOE_IN_CONTAINER=1

WORKDIR /project
ENTRYPOINT ["yoe"]
