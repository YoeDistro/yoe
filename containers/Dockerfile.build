# Yoe-NG build container (Tier 0)
# Version: 9
#
# Tools-only container. The host yoe binary is bind-mounted at runtime,
# not baked into the image. This means the container only rebuilds when
# the tool set changes, not when yoe itself is recompiled.

FROM alpine:3.21

RUN apk add --no-cache \
    bubblewrap \
    apk-tools \
    git \
    tar \
    gzip \
    bzip2 \
    xz \
    patch \
    coreutils \
    bash \
    make \
    gcc \
    g++ \
    musl-dev \
    linux-headers \
    sfdisk \
    e2fsprogs \
    dosfstools \
    mtools \
    syslinux \
    losetup \
    mount \
    qemu-system-x86_64 \
    ovmf \
    autoconf \
    automake \
    libtool \
    perl \
    bc \
    flex \
    bison \
    elfutils-dev \
    openssl-dev \
    diffutils \
    findutils \
    sed

# Create /build for bwrap bind mounts
RUN mkdir -p /build/src /build/destdir

# Create loop device nodes (needed for losetup in --privileged mode)
RUN for i in $(seq 0 7); do mknod -m 0660 /dev/loop$i b 7 $i 2>/dev/null || true; done

ENV YOE_IN_CONTAINER=1

WORKDIR /project
